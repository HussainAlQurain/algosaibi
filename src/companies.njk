---
layout: layouts/base.njk
title: "Companies"
description: "Explore the 19 companies in the Ahmad Hamad ALGOSAIBI & BROS CO. portfolio."
arLink: "ar/companies.html"
activePage: "companies"
permalink: "companies.html"
---

<section class="page-hero">
  <img src="assets/images/subsidiaries-banner.webp" alt="AHALGOSAIBI Companies" class="hero-bg-img" />
  <div class="hero-overlay"></div>
  <div class="hero-container">
    <div class="hero-copy reveal">
      <p class="eyebrow">Group Structure</p>
      <h1>Our <span>Companies</span></h1>
      <p>Our portfolio comprises 19 companies across the group.</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head centered reveal">
      <p class="eyebrow">Our Portfolio</p>
      <h2>All Companies</h2>
      <p style="color:var(--t2);max-width:60ch;margin:1rem auto 0;line-height:1.8;">All companies in our portfolio are listed below. Each card links to that business&rsquo;s public website when one is available.</p>
    </div>

    <div class="companies-cards-grid reveal">
      {% for sector in companies.sectors %}
        {% for company in sector.companies %}
        {% if company.url %}
        <a href="{{ company.url }}" target="_blank" rel="noopener" class="company-box company-box--link">
        {% else %}
        <div class="company-box company-box--no-link">
        {% endif %}
          <div class="company-box-logo">
            {% if company.logo %}
            <img src="{{ company.logo }}" alt="{{ company.en }}" />
            {% else %}
            <div class="company-box-logo-placeholder">{{ company.en | truncate(2, true, '') | upper }}</div>
            {% endif %}
          </div>
          <div class="company-box-body">
            <h4>{{ company.en }}</h4>
            <p>{{ company.description }}</p>
            {% if not company.url %}
            <span class="company-no-site">Website Coming Soon</span>
            {% else %}
            <span class="company-visit">Visit Website &rarr;</span>
            {% endif %}
          </div>
        {% if company.url %}
        </a>
        {% else %}
        </div>
        {% endif %}
        {% endfor %}
      {% endfor %}
    </div>

  </div>
</section>
