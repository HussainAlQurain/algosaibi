<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description | default('Ahmad Hamad ALGOSAIBI & BROS CO. is a Saudi family business founded in 1940, with a portfolio of companies and investments across six sectors.') }}" />
    <title>{{ title }} | AHALGOSAIBI Group</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="assets/css/styles.css" />
  </head>
  <body>
    <header class="site-header" id="top">
      <div class="container nav-wrap">
        <div class="header-brands">
          <a href="index.html" class="brand" aria-label="AHALGOSAIBI home">
            <img src="assets/images/logo.png" alt="AHALGOSAIBI Group logo" class="brand-logo" />
          </a>
          <img src="assets/images/Saudi_Vision_2030_logo.svg" alt="Saudi Vision 2030" class="vision-2030-logo" width="78" height="52" />
        </div>
        <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="Toggle navigation">
          <span></span><span></span><span></span>
        </button>
        <nav class="site-nav" id="navMenu">
          <a href="about.html" {% if activePage == 'about' %}aria-current="page" class="nav-active"{% endif %}>About&nbsp;Us</a>
          <a href="values.html" {% if activePage == 'values' %}aria-current="page" class="nav-active"{% endif %}>Values</a>
          <a href="history.html" {% if activePage == 'history' %}aria-current="page" class="nav-active"{% endif %}>History</a>
          <div class="nav-dropdown">
            <a href="companies.html" class="nav-dropdown-toggle" {% if activePage == 'companies' %}aria-current="page"{% endif %}>Companies</a>
            {% set navLang = "en" %}
            {% set navCompaniesHref = "companies.html" %}
            {% include "companies-nav-dropdown.njk" %}
          </div>
          <a href="media-events.html" {% if activePage == 'media' %}aria-current="page" class="nav-active"{% endif %}>Media&nbsp;&amp;&nbsp;Events</a>
          <a href="board.html" {% if activePage == 'board' %}aria-current="page" class="nav-active"{% endif %}>Board</a>
          <a href="contact.html" class="nav-cta{% if activePage == 'contact' or activePage == 'careers' %} nav-active{% endif %}" {% if activePage == 'contact' or activePage == 'careers' %}aria-current="page"{% endif %}>Careers&nbsp;&amp;&nbsp;Contact</a>
          <div class="lang-switch" role="group" aria-label="Language">
            <a href="index.html" class="lang-switch-btn is-active" aria-current="true">EN</a>
            <a href="{{ arLink | default('ar/index.html') }}" class="lang-switch-btn" id="langSwitchLabel" aria-label="Switch to Arabic">عربي</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    {% if showFooter %}
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <img src="assets/images/logo.png" alt="AHALGOSAIBI Group" class="footer-brand-logo" />
            <p class="footer-tagline">A Saudi family business founded in 1940, with companies and investments across six sectors in the Kingdom.</p>
          </div>
          <div class="footer-col">
            <h4>Quick Links</h4>
            <ul class="footer-links">
              <li><a href="about.html">About Us</a></li>
              <li><a href="values.html">Our Values</a></li>
              <li><a href="history.html">Our History</a></li>
              <li><a href="companies.html">Companies</a></li>
              <li><a href="board.html">Board of Directors</a></li>
              <li><a href="contact.html">Careers &amp; Contact</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Companies</h4>
            <ul class="footer-links">
              <li><a href="https://algosaibihotel.com/" target="_blank" rel="noopener">AlGosaibi Hotel</a></li>
              <li><a href="https://algosaibisports.com/" target="_blank" rel="noopener">AlGosaibi Sport Center</a></li>
              <li><a href="https://club8sa.com/" target="_blank" rel="noopener">Club 8</a></li>
              <li><a href="https://algosaibivillage.com/en-US/" target="_blank" rel="noopener">Al Gosaibi Village</a></li>
              <li><a href="https://mathaqat.com.sa/" target="_blank" rel="noopener">Mathaqat Foods</a></li>
              <li><a href="https://www.gac.com/saudi-arabia" target="_blank" rel="noopener">GAC Saudi Arabia</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <ul class="footer-contact-list">
              <li><strong>Phone</strong>+966 13 882 2666</li>
              <li><strong>Email</strong>info@ahalgosaibi.com</li>
              <li><strong>Careers</strong>join@ahalgosaibi.com</li>
              <li><strong>Location</strong>Eastern Province, Kingdom of Saudi Arabia</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container footer-bottom-wrap">
          <p>&copy; 2026 Ahmad Hamad Al-Gosaibi &amp; Bros. Co. All rights reserved.</p>
          <div style="display:flex;gap:1.2rem;align-items:center;">
            <a href="{{ arLink | default('ar/index.html') }}">&#1575;&#1604;&#1593;&#1585;&#1576;&#1610;&#1577;</a>
            <a href="#top">Back to top &uarr;</a>
          </div>
        </div>
      </div>
    </footer>
    {% endif %}

    <script src="assets/js/main.js"></script>
  </body>
</html>
