<!-- ═══════════════════════════════════════════════
     MISSION & VISION
═══════════════════════════════════════════════ -->
<section class="section" id="mission">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Our Purpose</p>
      <h2>Mission &amp; Vision</h2>
    </div>
    <div class="mission-grid reveal delay-1">
      <div class="mission-block">
        <span class="mission-block-tag">Mission</span>
        <p>To create lasting economic value through diversified, ethically-led business — honoring the pioneering legacy of our founders, contributing to the Kingdom's growth, and creating opportunity for our people and communities across Saudi Arabia.</p>
      </div>
      <div class="mission-block">
        <span class="mission-block-tag">Vision</span>
        <p>To be the most trusted and respected Saudi family business group — one that honors its roots, empowers its people, upholds the highest standards of integrity, and builds enduring value across every industry we serve.</p>
      </div>
    </div>
    <div class="mission-pillars reveal delay-2">
      <article class="card">
        <h3>Diversified Excellence</h3>
        <p>From manufacturing and energy to hospitality and media, we grow across industries to build resilient, long-term value for Saudi Arabia.</p>
      </article>
      <article class="card">
        <h3>Rooted in Responsibility</h3>
        <p>Social and environmental stewardship have always been central to our strategy — from community welfare societies to charitable contributions at home and abroad.</p>
      </article>
      <article class="card">
        <h3>Empowering Saudi Talent</h3>
        <p>We invest in our people, create meaningful careers, and actively contribute to Vision 2030 by nurturing a capable national workforce.</p>
      </article>
    </div>
  </div>
</section>

