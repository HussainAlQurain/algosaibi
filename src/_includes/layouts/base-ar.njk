<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description | default('أحمد حمد القصيبي وإخوانه شركة عائلية سعودية تأسست عام 1940، ولها محفظة من الشركات والاستثمارات عبر ستة قطاعات.') }}" />
    <title>{{ title }} | مجموعة القصيبي</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="../assets/css/styles.css" />
  </head>
  <body>
    <header class="site-header" id="top">
      <div class="container nav-wrap">
        <div class="header-brands">
          <a href="index.html" class="brand" aria-label="القصيبي الصفحة الرئيسية">
            <img src="../assets/images/logo.png" alt="شعار مجموعة القصيبي" class="brand-logo" />
          </a>
          <img src="../assets/images/Saudi_Vision_2030_logo.svg" alt="رؤية السعودية 2030" class="vision-2030-logo" width="78" height="52" />
        </div>
        <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="تبديل القائمة">
          <span></span><span></span><span></span>
        </button>
        <nav class="site-nav" id="navMenu">
          <a href="about.html" {% if activePage == 'about' %}aria-current="page" class="nav-active"{% endif %}>من نحن</a>
          <a href="values.html" {% if activePage == 'values' %}aria-current="page" class="nav-active"{% endif %}>قيمنا</a>
          <a href="history.html" {% if activePage == 'history' %}aria-current="page" class="nav-active"{% endif %}>تاريخنا</a>
          <div class="nav-dropdown">
            <a href="companies.html" class="nav-dropdown-toggle" {% if activePage == 'companies' %}aria-current="page"{% endif %}>الشركات</a>
            {% set navLang = "ar" %}
            {% set navCompaniesHref = "companies.html" %}
            {% include "companies-nav-dropdown.njk" %}
          </div>
          <a href="media-events.html" {% if activePage == 'media' %}aria-current="page" class="nav-active"{% endif %}>الإعلام&nbsp;والفعاليات</a>
          <a href="board.html" {% if activePage == 'board' %}aria-current="page" class="nav-active"{% endif %}>المجلس</a>
          <a href="contact.html" class="nav-cta{% if activePage == 'contact' or activePage == 'careers' %} nav-active{% endif %}" {% if activePage == 'contact' or activePage == 'careers' %}aria-current="page"{% endif %}>الوظائف&nbsp;والتواصل</a>
          <div class="lang-switch" role="group" aria-label="اللغة">
            <a href="index.html" class="lang-switch-btn is-active" aria-current="true">عربي</a>
            <a href="{{ enLink | default('../index.html') }}" class="lang-switch-btn" id="langSwitchLabel" aria-label="التبديل إلى الإنجليزية">إنجليزي</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    {% if showFooter %}
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <img src="../assets/images/logo.png" alt="مجموعة القصيبي" class="footer-brand-logo" />
            <p class="footer-tagline">شركة عائلية سعودية تأسست عام 1940، ولها شركات واستثمارات عبر ستة قطاعات في المملكة.</p>
          </div>
          <div class="footer-col">
            <h4>روابط سريعة</h4>
            <ul class="footer-links">
              <li><a href="about.html">من نحن</a></li>
              <li><a href="values.html">قيمنا</a></li>
              <li><a href="history.html">تاريخنا</a></li>
              <li><a href="companies.html">الشركات</a></li>
              <li><a href="board.html">مجلس الإدارة</a></li>
              <li><a href="contact.html">الوظائف والتواصل</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>الشركات</h4>
            <ul class="footer-links">
              <li><a href="https://algosaibihotel.com/" target="_blank" rel="noopener">فندق القصيبي</a></li>
              <li><a href="https://algosaibisports.com/" target="_blank" rel="noopener">مركز القصيبي الرياضي</a></li>
              <li><a href="https://club8sa.com/" target="_blank" rel="noopener">كلوب ثمانية</a></li>
              <li><a href="https://algosaibivillage.com/en-US/" target="_blank" rel="noopener">قرية القصيبي</a></li>
              <li><a href="https://mathaqat.com.sa/" target="_blank" rel="noopener">مذاقات</a></li>
              <li><a href="https://www.gac.com/saudi-arabia" target="_blank" rel="noopener">GAC Saudi Arabia</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>اتصل بنا</h4>
            <ul class="footer-contact-list">
              <li><strong>هاتف</strong>+966 13 882 2666</li>
              <li><strong>بريد إلكتروني</strong>info@ahalgosaibi.com</li>
              <li><strong>وظائف</strong>join@ahalgosaibi.com</li>
              <li><strong>الموقع</strong>المنطقة الشرقية، المملكة العربية السعودية</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container footer-bottom-wrap">
          <p>&copy; 2026 أحمد حمد القصيبي وإخوانه. جميع الحقوق محفوظة.</p>
          <div style="display:flex;gap:1.2rem;align-items:center;">
            <a href="{{ enLink | default('../index.html') }}">English</a>
            <a href="#top">العودة للأعلى &uarr;</a>
          </div>
        </div>
      </div>
    </footer>
    {% endif %}

    <script src="../assets/js/main.js"></script>
  </body>
</html>
